% Columbia University Color Theme for Gemini Poster
% Based on Columbia University Brand Guidelines
% https://visualidentity.columbia.edu/colors

% ====================
% Definitions
% ====================

% Columbia University official colors
\definecolor{columbiablue}{RGB}{0, 48, 135}      % Columbia Dark Blue (primary)
\definecolor{columbiaaccent}{RGB}{117, 170, 219} % Columbia Light Blue (accent)

% Extra colors
\definecolor{lightgray}{RGB}{240, 240, 240}
\definecolor{lightorange}{RGB}{255, 245, 242}
\definecolor{lightblue}{RGB}{232, 241, 250}

% ====================
% Theme
% ====================

% Basic colors
\setbeamercolor{palette primary}{fg=black,bg=white}
\setbeamercolor{palette secondary}{fg=black,bg=white}
\setbeamercolor{palette tertiary}{bg=black,fg=white}
\setbeamercolor{palette quaternary}{fg=black,bg=white}
\setbeamercolor{structure}{fg=columbiablue}

% Headline
\setbeamercolor{headline}{fg=white,bg=columbiablue}

% Block
\setbeamercolor{block title}{fg=columbiablue,bg=white}
\setbeamercolor{block separator}{bg=columbiaaccent}
\setbeamercolor{block body}{fg=black,bg=white}

% Alert Block
\setbeamercolor{block alerted title}{fg=columbiablue,bg=lightblue}
\setbeamercolor{block alerted separator}{bg=columbiaaccent}
\setbeamercolor{block alerted body}{fg=black,bg=lightblue}

% Example Block
\setbeamercolor{block example title}{fg=columbiablue,bg=lightgray}
\setbeamercolor{block example separator}{bg=columbiaaccent}
\setbeamercolor{block example body}{fg=black,bg=lightgray}

% Heading
\setbeamercolor{heading}{fg=columbiablue}

% Itemize
\setbeamercolor{item}{fg=columbiaaccent}

% Bibliography
\setbeamercolor{bibliography item}{fg=black}
\setbeamercolor{bibliography entry author}{fg=black}
\setbeamercolor{bibliography entry title}{fg=black}
\setbeamercolor{bibliography entry location}{fg=black}
\setbeamercolor{bibliography entry note}{fg=black}
